<SectionHeader Id="projects" Title="Personal Projects">
    <ScrollableCardContainer>
        @foreach (var project in PortfolioData.Projects)
        {
            <MudCard Class="project-card" Elevation="0">
                <MudCardContent Class="project-card-content">
                    <MudText Typo="Typo.subtitle1" Style="color: #e2e8f0; font-weight: 500;">
                        @project.Name
                    </MudText>
                    <MudText Typo="Typo.body2" Style="margin-top: 0.5rem; flex-grow: 1;">
                        @project.Description
                    </MudText>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.5rem;">
                        @foreach (var tag in project.Tags)
                        {
                            <MudChip T="string" Class="skill-chip" Size="Size.Small" Variant="Variant.Filled">
                                @tag
                            </MudChip>
                        }
                    </div>
                </MudCardContent>
                <MudCardActions>
                    @if (project.Link is not null)
                    {
                        <MudButton Href="@project.Link"
                                   Target="_blank"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.OpenInNew"
                                   Size="Size.Small">
                            Try it
                        </MudButton>
                    }
                    @if (project.Code is not null)
                    {
                        <MudButton Href="@project.Code"
                                   Target="_blank"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.OpenInNew"
                                   Size="Size.Small">
                            View Code
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        }
    </ScrollableCardContainer>
</SectionHeader>
